{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "framework_version",
    "coverage",
    "persistence_mode",
    "findings"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "framework_version": {"type": "string"},
    "methodology_version": {"type": "string"},
    "fingerprint_version": {"type": "string"},
    "coverage": {
      "enum": ["full", "partial", "batched", "risk-based", "sample"]
    },
    "persistence_mode": {"enum": ["read-only", "default", "persist"]},
    "findings": {"type": "array", "items": {"$ref": "finding.schema.json"}}
  }
}
